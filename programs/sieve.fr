
uint32_t n = 80

array<char> isPrime
isPrime(n + 1)
isPrime.memset(0b00000001)

isPrime[0] = 0
if (n >= 1) {
    isPrime[1] = 0
}

uint32_t p = 2
while (p * p <= n) {
    if (isPrime[p] != 0) {
        uint32_t j = p * p
        while (j <= n) {
            isPrime[j] = 0
            j = j + p
        }
    }
    p = p + 1
}

uint32_t i = 2
while (i <= n) {
    if (isPrime[i] != 0) {
        print(i)
    }
    i = i + 1
}

isPrime.uninit()
