// ============================================================
// Franko Iterative Quicksort Showcase: 50 Elements
// Function-Based Version
// ============================================================
//
// Demonstrates:
//
//   - func declarations
//   - void functions
//   - non-void return values
//   - addr<array<T, N>> array passing
//   - alloced static array
//   - del
//   - local static arrays as an explicit stack
//   - while-loop-based quicksort
//   - uint32_t indexes
//   - int32_t values
//   - swapping array elements
//
// Arrays are passed by address because Franko arrays are not
// directly assignable or returnable by value.
// ============================================================


// ------------------------------------------------------------
// Print array contents
// ------------------------------------------------------------

func printArray(addr<array<int32_t, 50>> data, uint32_t n) -> void {
    uint32_t i = 0

    while (i < n) {
        print(deref(data)[i])
        i = i + 1
    }
}


// ------------------------------------------------------------
// Initialize unsorted data
// ------------------------------------------------------------

func initData(addr<array<int32_t, 50>> data) -> void {
    deref(data)[0] = 42
    deref(data)[1] = 7
    deref(data)[2] = 19
    deref(data)[3] = 3
    deref(data)[4] = 100
    deref(data)[5] = 55
    deref(data)[6] = 1
    deref(data)[7] = 88
    deref(data)[8] = 12
    deref(data)[9] = 33

    deref(data)[10] = 21
    deref(data)[11] = 5
    deref(data)[12] = 77
    deref(data)[13] = 60
    deref(data)[14] = 2
    deref(data)[15] = 50
    deref(data)[16] = 91
    deref(data)[17] = 14
    deref(data)[18] = 39
    deref(data)[19] = 73

    deref(data)[20] = 8
    deref(data)[21] = 65
    deref(data)[22] = 27
    deref(data)[23] = 44
    deref(data)[24] = 6
    deref(data)[25] = 99
    deref(data)[26] = 31
    deref(data)[27] = 58
    deref(data)[28] = 16
    deref(data)[29] = 82

    deref(data)[30] = 24
