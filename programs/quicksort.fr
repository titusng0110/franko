}


// ------------------------------------------------------------
// Swap two elements
// ------------------------------------------------------------

func swap(
    addr<array<int32_t, 50>> data,
    uint32_t a,
    uint32_t b
) -> void {
    int32_t temp = 0

    temp = deref(data)[a]
    deref(data)[a] = deref(data)[b]
    deref(data)[b] = temp
}


// ------------------------------------------------------------
// Lomuto partition
// ------------------------------------------------------------
//
// Partitions:
//
//   data[low..high]
//
// around:
//
//   pivot = data[high]
//
// Returns the final pivot index.
// ------------------------------------------------------------

func partition(
    addr<array<int32_t, 50>> data,
    uint32_t low,
    uint32_t high
) -> uint32_t {
    int32_t pivot = 0
    uint32_t i = 0
    uint32_t j = 0

    pivot = deref(data)[high]

    i = low
    j = low

    while (j < high) {
        if (deref(data)[j] <= pivot) {
            swap(data, i, j)
            i = i + 1
        }

        j = j + 1
    }

    swap(data, i, high)

    return i
}


// ------------------------------------------------------------
// Iterative quicksort
// ------------------------------------------------------------
//
// Uses two local static arrays as an explicit recursion stack:
//
//   stackLow[top]
//   stackHigh[top]
//
// Each stack entry stores one pending range:
//
//   [low, high]
// ------------------------------------------------------------

func quicksort(
    addr<array<int32_t, 50>> data,
    uint32_t n
) -> void {
    array<uint32_t, 128> stackLow
    array<uint32_t, 128> stackHigh

    uint32_t top = 0

    uint32_t low = 0
    uint32_t high = 0
    uint32_t pi = 0

    // Push initial full range [0, n - 1]
    stackLow[top] = 0
    stackHigh[top] = n - 1
    top = top + 1

    while (top != 0) {
        // Pop one range
        top = top - 1

        low = stackLow[top]
        high = stackHigh[top]

        // Only sort ranges with at least two elements
        if (low < high) {
            pi = partition(data, low, high)

            // Push left range [low, pi - 1]
            //
            // Guard with pi > low to avoid uint32_t underflow.
            if (pi > low) {
                stackLow[top] = low
                stackHigh[top] = pi - 1
                top = top + 1
            }

            // Push right range [pi + 1, high]
            //
            // Guard with pi < high so pi + 1 is valid.
            if (pi < high) {
                stackLow[top] = pi + 1
                stackHigh[top] = high
                top = top + 1
            }
        }
    }
}


// ------------------------------------------------------------
// Verification pass
// ------------------------------------------------------------
//
// Returns:
//
//   1 if sorted
//   0 otherwise
// ------------------------------------------------------------

func isSorted(
    addr<array<int32_t, 50>> data,
    uint32_t n
) -> uint8_t {
    uint32_t k = 1
    uint8_t sorted = 1

    while (k < n) {
        if (deref(data)[k] < deref(data)[k - 1]) {
            sorted = 0
        }

        k = k + 1
    }

    return sorted
}


// ------------------------------------------------------------
// Main
// ------------------------------------------------------------

func main() -> int32_t {
    alloc array<int32_t, 50> data

    uint32_t n = 50
    uint8_t sorted = 0

    initData(getaddr(data))

    // Print unsorted array
    print(2001)
    printArray(getaddr(data), n)

    quicksort(getaddr(data), n)

    // Print sorted array
    print(2002)
    printArray(getaddr(data), n)

    // Verify sortedness
    sorted = isSorted(getaddr(data), n)

    print(2003)
    print(sorted)

    del data

    return 0
}